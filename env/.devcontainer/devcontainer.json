{
  "name": "Yasumi Frontend",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": "../..",
    "target": "dev"
  },
  "workspaceFolder": "/workspace",
  "forwardPorts": [5173, 4175, 7659, 8081],
